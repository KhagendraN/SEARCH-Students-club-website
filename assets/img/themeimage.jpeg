<?xml version="1.0" encoding="utf-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="600" viewBox="0 0 1200 600" role="img" aria-label="SEARCH hero image">
  <defs>
    <linearGradient id="bg" x1="0" x2="1">
      <stop offset="0%" stop-color="#f6efe6"/>
      <stop offset="100%" stop-color="#eaf5ea"/>
    </linearGradient>
    <linearGradient id="leaf" x1="0" x2="1">
      <stop offset="0%" stop-color="#4a7a46"/>
      <stop offset="100%" stop-color="#2f5a33"/>
    </linearGradient>
  </defs>

  <rect width="100%" height="100%" fill="url(#bg)"/>

  <!-- soft vignette -->
  <rect x="0" y="0" width="1200" height="600" fill="black" opacity="0.02"/>

  <!-- large leaf motif on left -->
  <g transform="translate(80,120) scale(1)">
    <path d="M0,260 C60,80 260,40 420,20 C340,120 200,240 140,300 C80,360 20,320 0,260" fill="url(#leaf)" opacity="0.95"/>
    <path d="M60,300 C140,180 320,140 460,120" stroke="#2a4f2a" stroke-width="6" fill="none" stroke-linecap="round"/>
  </g>

  <!-- secondary leaves on right -->
  <g transform="translate(760,160) scale(1)">
    <path d="M0,220 C40,120 160,80 260,60 C220,140 160,200 100,250 C40,300 0,260 0,220" fill="url(#leaf)" opacity="0.9"/>
  </g>

  <!-- saffron sunrise accent -->
  <circle cx="920" cy="120" r="90" fill="#e07a2e" opacity="0.12"/>
  <circle cx="920" cy="120" r="40" fill="#f6d6b0" opacity="0.3"/>

  <!-- subtle texture lines -->
  <g opacity="0.06" stroke="#b8cdb8" stroke-width="2">
    <path d="M0,480 C220,360 460,400 720,360 C980,320 1200,380 1200,380" fill="none"/>
  </g>

  <!-- small logo mark in top-left -->
  <g transform="translate(40,40) scale(0.14)">
    <circle cx="300" cy="300" r="300" fill="#fff" stroke="#2f5a33" stroke-width="18"/>
    <path d="M300,200 v80 M300,280 c25,12 25,60 0,72 c-25,12 -25,60 0,72" stroke="#1f3d2a" stroke-width="16" stroke-linecap="round" fill="none"/>
  </g>

  <!-- headline placeholder (transparent, page uses separate text) -->
  <g transform="translate(420,160)">
    <text x="0" y="0" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-size="44" fill="#2f5a33" opacity="0.0">SEARCH Students' Club</text>
  </g>

</svg>
